{
  "name": "link-converter",
  "version": "1.0.0",
  "description": "Video download backend using yt-dlp",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "postinstall": "curl -L https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp_linux -o /usr/local/bin/yt-dlp && chmod a+rx /usr/local/bin/yt-dlp"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  }
}
